# Gmail App Password chahiye — regular password kaam nahi karega
# Steps:
# 1. myaccount.google.com → Security → 2-Step Verification ON karo
# 2. myaccount.google.com/apppasswords → New app password → "Mail" → Generate
# 3. Woh 16-digit password yahan paste karo (spaces hata ke)

GMAIL_USER=manishcyber82@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Kitni companies ko ek baar mein email bhejo (daily limit ke liye)
BATCH_SIZE=15
