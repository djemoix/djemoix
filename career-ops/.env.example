# --- GMAIL SETUP (required for email-blast) ---
# Step 1: myaccount.google.com → Security → 2-Step Verification ON
# Step 2: myaccount.google.com/apppasswords → Mail → Generate
# Step 3: Paste the 16-digit password below (remove spaces)

GMAIL_USER=manishcyber82@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# --- EMAIL SETTINGS ---
# Kitni companies ko ek run mein email karo (Gmail daily limit: 500)
BATCH_SIZE=15
